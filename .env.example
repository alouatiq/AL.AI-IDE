# Copy to .env.local for `vercel dev`, OR set these in
# Vercel → Project → Settings → Environment Variables.
#
# Every variable is OPTIONAL. Each one you set enables that provider's SERVER-SIDE
# key, so your visitors can use the AI chat without pasting their own key. Users can
# always add their own key in Settings for any provider you leave unset — and the
# app also works as a pure static site (bring-your-own-key) with none of these set.

# OpenRouter — huge free model list incl. top coding models (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# AgentRouter — non-profit gateway to Claude / GPT / DeepSeek / GLM, free credits
# (https://agentrouter.org/console/token)
# AGENTROUTER_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Groq — very fast, free (https://console.groq.com/keys)
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini — free tier (https://aistudio.google.com/app/apikey)
# GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cerebras — very fast, free (https://cloud.cerebras.ai/)
# CEREBRAS_API_KEY=csk-xxxxxxxxxxxxxxxxxxxxxxxx
